interface Food {
    void order();
}

class Pizza implements Food {
    public void order() {
        System.out.println("Pizza Ordered");
    }
}

class Burger implements Food {
    public void order() {
        System.out.println("Burger Ordered");
    }
}

class Beverage implements Food {
    public void order() {
        System.out.println("Beverage Ordered");
    }
}

public class Main {
    public static void main(String[] args) {
        Food f;

        f = new Pizza();
        f.order();

        f = new Burger();
        f.order();

        f = new Beverage();
        f.order();
    }
}
